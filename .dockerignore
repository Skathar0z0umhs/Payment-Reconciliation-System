# Python cache / build artifacts
__pycache__/
*.pyc
.pytest_cache/

# Virtual environments
venv/
.venv/
env/

# Logs
*.log

# Git
.git/
.gitignore

# Data files — keep financial CSVs OUT of the image (users upload via the app)
*.csv
*.CSV
*.xlsx

# Database + data folder — lives in a Docker VOLUME, not in the image
data/
*.db

# Personal / local-only files — the app uses conf_example.py, not these
reconciliation/configuration.py
playground.py

# Editor / OS junk
.vscode/
.idea/
.DS_Store
